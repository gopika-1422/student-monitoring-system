# App
APP_NAME="AI Smart Attendance System"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite+aiosqlite:///./attendance.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/attendance_db

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# AI Models
FACE_RECOGNITION_THRESHOLD=0.6
EMOTION_DETECTION_ENABLED=true
ATTENTION_TRACKING_ENABLED=true
FRAME_SKIP=3
MIN_PRESENCE_SECONDS=300

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Storage
STORAGE_PATH=./storage
IMAGES_PATH=./storage/images
EMBEDDINGS_PATH=./storage/embeddings
EXPORTS_PATH=./storage/exports
